# ConnectOS local development defaults.
#
# Copy this file to apps/web/.env.local for local development.
# Fill in only the providers you want to verify. ConnectOS uses mock fallback
# where supported when third-party credentials are missing.
#
# Never commit real secrets. Keep production secrets in a deployment secret
# manager, not in Git.
#
# See docs/ENVIRONMENT.md for the full reference.

# Core runtime.
#
# Enables Prisma-backed persistent storage. Leave empty for local demo mode
# with in-memory fallback. In-memory state does not survive process restarts.
# Example local Postgres URL:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/connect_any_inbox"
DATABASE_URL=""

# Browser-facing app origin used by local OAuth redirect UI flows.
NEXT_PUBLIC_APP_URL="http://localhost:3033"

# Required for real Google or Slack OAuth.
# Real direct OAuth is disabled until encrypted token storage is configured.
# Leave empty for mock fallback mode.
# Use a stable value in any environment with persisted OAuth token records;
# changing it makes existing encrypted token records unreadable.
CONNECT_CORE_ENCRYPTION_KEY=""

# Google direct OAuth for Gmail and Google Calendar.
# Set only after CONNECT_CORE_ENCRYPTION_KEY is configured.
# Leave empty for mock fallback mode.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3033/api/connect-core/callback"

# Slack direct OAuth.
# Set only after CONNECT_CORE_ENCRYPTION_KEY is configured.
# Leave empty for mock fallback mode.
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI="http://localhost:3033/api/connect-core/callback"

# Composio provider.
# Leave COMPOSIO_API_KEY empty for mock fallback mode.
# Store real API keys in deployment secrets, not in Git.
COMPOSIO_API_KEY=""
COMPOSIO_BASE_URL="https://backend.composio.dev"

# Optional JSON map of ConnectOS integration IDs to Composio auth config IDs.
# Leave empty until you have created matching auth configs in Composio.
# Example shape:
# COMPOSIO_AUTH_CONFIG_IDS='{"github":"ac_123"}'
COMPOSIO_AUTH_CONFIG_IDS=""
